{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "Testes automatizados E2E (frontend) e API para a aplicação ServeRest utilizando Cypress",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:frontend": "cypress run --spec cypress/e2e/frontend/**/*.cy.js",
    "cy:run:api": "cypress run --spec cypress/e2e/api/**/*.cy.js",
    "lint": "eslint cypress/ --ext .js",
    "lint:fix": "eslint cypress/ --ext .js --fix",
    "format": "prettier --write \"cypress/**/*.js\"",
    "format:check": "prettier --check \"cypress/**/*.js\"",
    "prereport": "npm run report:clean",
    "report": "npm run report:merge && npm run report:generate && npm run report:cleanup",
    "report:clean": "rimraf cypress/reports",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/mochawesome-report/report.json",
    "report:generate": "marge cypress/reports/mochawesome-report/report.json -f report -o cypress/reports/mochawesome-report",
    "report:cleanup": "rimraf cypress/reports/mochawesome_*.json cypress/reports/mochawesome-report/report.json",
    "test": "npm run cy:run",
    "test:report": "npm run report:clean && npm run cy:run && npm run report"
  },
  "keywords": ["cypress", "testing", "e2e", "api", "serverest", "qa"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "cypress": "^13.17.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0"
  }
}
